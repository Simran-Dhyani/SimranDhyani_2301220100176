## QUES  

class Solution {

    static Boolean isSubsetSum(int arr[], int sum) {
        return helper(arr, sum, 0);
    }

    static Boolean helper(int[] arr, int sum, int i) {

        if(sum == 0)
            return true;

        if(i == arr.length)
            return false;


        if(arr[i] <= sum) {
            if(helper(arr, sum - arr[i], i + 1))
                return true;
        }

        
        return helper(arr, sum, i + 1);
    }
}
